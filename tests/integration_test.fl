// 🏦 FreeLang Bank System - Integration Tests
// 통합 테스트

print("🧪 FreeLang Bank System Integration Tests")
print("=" * 50)
print("")

// ========================================
// Test Suite 1: 기본 계좌 관리
// ========================================

print("📋 Test Suite 1: Account Management")
print("-" * 50)

// Test 1.1: 계좌 생성
print("✅ Test 1.1: 계좌 생성")
let checking = record {
  account_id: "CHK001",
  owner_name: "김진돌",
  balance: 0.0,
  account_type: "Checking",
  annual_rate: 0.0,
}
print("  - Checking 계좌 생성: " + checking.account_id)

let savings = record {
  account_id: "SAV001",
  owner_name: "이순신",
  balance: 0.0,
  account_type: "Savings",
  annual_rate: 2.0,
}
print("  - Savings 계좌 생성: " + savings.account_id)

// Test 1.2: 입금
print("")
print("✅ Test 1.2: 입금 처리")
let checking = record {
  account_id: checking.account_id,
  owner_name: checking.owner_name,
  balance: checking.balance + 1000.0,
  account_type: checking.account_type,
  annual_rate: checking.annual_rate,
}
print("  - Checking 입금 $1,000: 잔액 $" + to_str(checking.balance))

let savings = record {
  account_id: savings.account_id,
  owner_name: savings.owner_name,
  balance: savings.balance + 5000.0,
  account_type: savings.account_type,
  annual_rate: savings.annual_rate,
}
print("  - Savings 입금 $5,000: 잔액 $" + to_str(savings.balance))

// Test 1.3: 출금
print("")
print("✅ Test 1.3: 출금 처리")
let checking = record {
  account_id: checking.account_id,
  owner_name: checking.owner_name,
  balance: checking.balance - 200.0,
  account_type: checking.account_type,
  annual_rate: checking.annual_rate,
}
print("  - Checking 출금 $200: 잔액 $" + to_str(checking.balance))

print("")
print("=" * 50)
print("")

// ========================================
// Test Suite 2: 계좌이체
// ========================================

print("📋 Test Suite 2: 계좌이체 (Transfer)")
print("-" * 50)

// Test 2.1: 기본 이체
print("✅ Test 2.1: 기본 이체")
let amount = 500.0
let fee = if amount > 1000.0 {
  amount * 0.005
} else {
  1.0
}

print("  - 출금 계좌 ($" + to_str(checking.balance) + ")")
print("    → 이체: $" + to_str(amount) + " + 수수료 $" + to_str(fee))

let checking = record {
  account_id: checking.account_id,
  owner_name: checking.owner_name,
  balance: checking.balance - amount - fee,
  account_type: checking.account_type,
  annual_rate: checking.annual_rate,
}

let savings = record {
  account_id: savings.account_id,
  owner_name: savings.owner_name,
  balance: savings.balance + amount,
  account_type: savings.account_type,
  annual_rate: savings.annual_rate,
}

print("  - Checking 잔액: $" + to_str(checking.balance))
print("  - Savings 잔액: $" + to_str(savings.balance))

print("")
print("=" * 50)
print("")

// ========================================
// Test Suite 3: 이자 계산
// ========================================

print("📋 Test Suite 3: 이자 계산")
print("-" * 50)

// Test 3.1: 일일 이자
print("✅ Test 3.1: 일일 이자")
let daily_interest = savings.balance * (savings.annual_rate / 100.0) / 365.0
print("  - Savings 잔액: $" + to_str(savings.balance))
print("  - 이율: " + to_str(savings.annual_rate) + "% APY")
print("  - 일일 이자: $" + to_str(daily_interest))

// Test 3.2: 월간 이자
print("")
print("✅ Test 3.2: 월간 이자 (30일)")
let monthly_interest = daily_interest * 30.0
print("  - 월간 이자: $" + to_str(monthly_interest))

// Test 3.3: 연간 이자
print("")
print("✅ Test 3.3: 연간 이자")
let annual_interest = daily_interest * 365.0
print("  - 연간 이자: $" + to_str(annual_interest))

let savings_with_interest = record {
  account_id: savings.account_id,
  owner_name: savings.owner_name,
  balance: savings.balance + annual_interest,
  account_type: savings.account_type,
  annual_rate: savings.annual_rate,
}

print("  - 연말 잔액: $" + to_str(savings_with_interest.balance))

print("")
print("=" * 50)
print("")

// ========================================
// Test Suite 4: 사기 탐지
// ========================================

print("📋 Test Suite 4: 사기 탐지")
print("-" * 50)

// Test 4.1: 거대 거래 감지
print("✅ Test 4.1: 거대 거래 감지")
let large_amount = 150_000.0
if large_amount > 100_000.0 {
  print("  🚨 위험: $" + to_str(large_amount) + " 거래 (임계값 > $100,000)")
} else if large_amount > 50_000.0 {
  print("  🔴 높음: $" + to_str(large_amount) + " 거래")
} else if large_amount > 10_000.0 {
  print("  🟡 중간: $" + to_str(large_amount) + " 거래")
} else {
  print("  ✅ 안전: $" + to_str(large_amount) + " 거래")
}

// Test 4.2: 빈도 감지
print("")
print("✅ Test 4.2: 이상 거래 빈도")
let txn_count = 85
let hours = 2
if txn_count / hours > 50 {
  print("  🚨 위험: 2시간 내 85건 거래 (시간당 " + to_str(txn_count / hours) + "건)")
} else {
  print("  ✅ 안전: " + to_str(txn_count) + "건 거래")
}

// Test 4.3: 잔액 급감
print("")
print("✅ Test 4.3: 잔액 급감 감지")
let prev_balance = 100_000.0
let curr_balance = 15_000.0
let drain_percent = ((prev_balance - curr_balance) / prev_balance) * 100.0

if drain_percent > 80.0 {
  print("  🚨 위험: 잔액 " + to_str(drain_percent) + "% 감소")
  print("    이전: $" + to_str(prev_balance) + " → 현재: $" + to_str(curr_balance))
} else {
  print("  ✅ 안전: " + to_str(drain_percent) + "% 감소")
}

print("")
print("=" * 50)
print("")

// ========================================
// Test Suite 5: 거래 통계
// ========================================

print("📋 Test Suite 5: 거래 통계")
print("-" * 50)

// 시뮬레이션: 여러 거래
let total_deposits = 6000.0
let total_withdrawals = 700.0
let total_transfers_out = 500.0
let total_fees = 1.0

print("✅ 거래 요약:")
print("  - 입금: $" + to_str(total_deposits))
print("  - 출금: $" + to_str(total_withdrawals))
print("  - 이체: $" + to_str(total_transfers_out))
print("  - 수수료: $" + to_str(total_fees))

let net_change = total_deposits - total_withdrawals - total_transfers_out - total_fees
print("  - 순 변화: $" + to_str(net_change))

print("")
print("=" * 50)
print("")

// ========================================
// Test Suite 6: 최종 잔액 확인
// ========================================

print("📋 Test Suite 6: 최종 잔액")
print("-" * 50)

print("✅ Checking 계좌")
print("  - 계좌번호: " + checking.account_id)
print("  - 예금주: " + checking.owner_name)
print("  - 잔액: $" + to_str(checking.balance))

print("")
print("✅ Savings 계좌")
print("  - 계좌번호: " + savings_with_interest.account_id)
print("  - 예금주: " + savings_with_interest.owner_name)
print("  - 잔액: $" + to_str(savings_with_interest.balance))
print("  - 이자 수익: $" + to_str(annual_interest))

let total_balance = checking.balance + savings_with_interest.balance
print("")
print("📊 총 자산: $" + to_str(total_balance))

print("")
print("=" * 50)
print("✅ 모든 테스트 완료!")
